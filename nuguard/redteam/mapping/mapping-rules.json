{
  "_comment": "Xelo AI-SBOM → NuGuard Attack Surface Graph mapping rules. Aligned with Xelo aibom-schema v1.3.0. Implemented in src/graph/mapper.py and src/graph/enricher.py.",

  "component_type_to_node_type": {
    "AGENT":           "agent",
    "MODEL":           "model",
    "TOOL":            "tool",
    "PROMPT":          "prompt",
    "DATASTORE":       "database",
    "GUARDRAIL":       "guardrail",
    "AUTH":            "identity",
    "PRIVILEGE":       "privilege",
    "IAM":             "iam",
    "API_ENDPOINT":    "api_endpoint",
    "FRAMEWORK":       "agent",
    "CONTAINER_IMAGE": null,
    "DEPLOYMENT":      null
  },

  "datastore_subtype_overrides": {
    "_comment": "When DATASTORE node metadata.datastore_type matches one of these keywords, override node_type to 'vectorstore'.",
    "vectorstore_keywords": ["chromavector", "chroma", "pinecone", "weaviate", "qdrant", "milvus", "faiss", "pgvector", "opensearch-vector"]
  },

  "relationship_type_to_edge_type": {
    "USES":     "INVOKES",
    "CALLS":    "INVOKES",
    "ACCESSES": "READS",
    "PROTECTS": "GUARDS",
    "DEPLOYS":  null
  },

  "accesses_write_conditions": [
    "source node is PRIVILEGE with privilege_scope containing '_write'",
    "target DATASTORE node metadata.write_access == true"
  ],

  "risk_attribute_rules": [
    {
      "condition": "node_type in ['tool', 'api_endpoint'] AND metadata.auth_type == 'none'",
      "assign": "no-auth-required"
    },
    {
      "condition": "node_type in ['database', 'vectorstore'] AND 'PII' in metadata.data_classification OR 'PHI' in metadata.data_classification",
      "assign": "PII-stores"
    },
    {
      "condition": "node_type == 'privilege' AND metadata.privilege_scope in ['db_write', 'filesystem_write', 'code_execution', 'network_out', 'admin']",
      "assign": "high-privilege"
    },
    {
      "condition": "node_type == 'api_endpoint' AND metadata.method in ['POST', 'PUT', 'PATCH', 'DELETE'] AND metadata.auth_type == 'none'",
      "assign": "IDOR-surface"
    },
    {
      "condition": "node_type in ['tool', 'api_endpoint'] AND rate_limited == false",
      "assign": "no-rate-limit"
    },
    {
      "condition": "node_type in ['agent', 'api_endpoint'] AND accepts_external_network_calls == true",
      "assign": "SSRF-possible"
    },
    {
      "condition": "node_type in ['agent', 'tool'] AND (memory_access == true OR is_connected_to_vectorstore)",
      "assign": "HITL-bypass-risk"
    },
    {
      "condition": "node_type in ['database', 'vectorstore'] AND metadata.auth_type == 'none'",
      "assign": "SQL-injectable"
    }
  ]
}
