# NuGuard local environment template
# Fill only the vars you need for your workflow.

# -----------------------------------------------------------------------------
# LLM keys (set at least one when using `--llm` features)
# -----------------------------------------------------------------------------
LITELLM_API_KEY=your_litellm_or_provider_key
AZURE_API_KEY=your_azure_openai_key
AZURE_OPENAI_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
ANTHROPIC_API_KEY=
GEMINI_API_KEY=your_gemini_api_key
OPENAI_API_KEY=your_openai_api_key
GEMINI_MODEL_NAME=gemini-3.1-flash-lite-preview

# SBOM generation variables currently used by nuguard sbom generate
# - XELO_LLM_MODEL / XELO_LLM_API_KEY / XELO_LLM_API_BASE / XELO_LLM_BUDGET_TOKENS are active.
# - LITELLM_API_KEY is also read by top-level llm config paths.
# - AISBOM_* names below are legacy aliases kept for backward compatibility.
XELO_LLM_API_KEY=your_litellm_or_provider_key
XELO_LLM_MODEL=azure/gpt-4.1
XELO_LLM_API_BASE=

AISBOM_LLM_API_KEY=

# -----------------------------------------------------------------------------
# Redteam/eval LLM (optional; used by redteam.llm / redteam.eval_llm)
# -----------------------------------------------------------------------------
NUGUARD_REDTEAM_EVAL_LLM_MODEL=azure/gpt-4.1
NUGUARD_REDTEAM_EVAL_LLM_API_KEY=your_redteam_eval_llm_api_key
NUGUARD_REDTEAM_LLM_MODEL=azure/gpt-4.1
NUGUARD_REDTEAM_LLM_API_KEY=your_redteam_llm_api_key
NUGUARD_REDTEAM_GUIDED_MUTATION_MODE=soft
# Optional redteam LLM temperature tuning (defaults shown)
#NUGUARD_REDTEAM_PROMPT_GENERATION_TEMPERATURE=0.7
#NUGUARD_REDTEAM_MUTATION_TEMPERATURE=0.85
#NUGUARD_REDTEAM_PLAN_TEMPERATURE=0.7
#NUGUARD_REDTEAM_NEXT_TURN_TEMPERATURE=0.9
#NUGUARD_REDTEAM_PROGRESS_EVAL_TEMPERATURE=0.2
#NUGUARD_REDTEAM_HAPPY_PATH_TEMPERATURE=0.9

# -----------------------------------------------------------------------------
# Target app auth placeholders (optional; used by validate/redteam auth headers)
# -----------------------------------------------------------------------------
TARGET_TOKEN=
TARGET_API_KEY=
APP_USERNAME=
APP_PASSWORD=

# -----------------------------------------------------------------------------
# Repo access token for --from-repo private scans (optional)
# -----------------------------------------------------------------------------
GH_TOKEN=
GITHUB_TOKEN=

# -----------------------------------------------------------------------------
# Optional data/backend vars used in some configs/tests
# -----------------------------------------------------------------------------
DATABASE_URL=
SOME_API_KEY=
LAST_GOOD_RUN=
STOCK_ASSIST_SESSION_COOKIE=
